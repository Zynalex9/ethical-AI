# Environment Configuration for Ethical AI Platform

# Application
APP_NAME="Ethical AI Requirements Engineering Platform"
APP_VERSION="1.0.0"
DEBUG=true
API_PREFIX="/api/v1"

# Server
HOST=0.0.0.0
PORT=8000

# Database (PostgreSQL)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/ethical_ai
DATABASE_ECHO=false

# Redis
REDIS_URL=redis://localhost:6379/0

# JWT Authentication (CHANGE IN PRODUCTION!)
JWT_SECRET_KEY=change-this-to-a-secure-random-key-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# File Storage
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE_MB=100

# MLflow
MLFLOW_TRACKING_URI=sqlite:///mlflow.db
MLFLOW_EXPERIMENT_NAME=ethical-ai-validations

# Celery
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# CORS (comma-separated for multiple origins)
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]
